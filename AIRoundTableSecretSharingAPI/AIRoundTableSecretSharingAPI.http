@AIRoundTableSecretSharingAPI_HostAddress = http://localhost:5149

### Authenticate as partnerA
# @name partnerAAuth
POST {{AIRoundTableSecretSharingAPI_HostAddress}}/auth/token
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials&client_id=partnerA&client_secret=pA-client-secret-2026-abc123

### Authenticate as admin
# @name adminAuth
POST {{AIRoundTableSecretSharingAPI_HostAddress}}/auth/token
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials&client_id=admin&client_secret=admin-secret-2026-CHANGE-ME

### Get current epoch
GET {{AIRoundTableSecretSharingAPI_HostAddress}}/api/registry/epoch
Accept: application/json
Authorization: Bearer {{partnerAAuth.response.body.accessToken}}

### Get active producers
GET {{AIRoundTableSecretSharingAPI_HostAddress}}/api/registry/producers
Accept: application/json
Authorization: Bearer {{partnerAAuth.response.body.accessToken}}

### Get all public keys
GET {{AIRoundTableSecretSharingAPI_HostAddress}}/api/keyexchange/keys
Accept: application/json
Authorization: Bearer {{partnerAAuth.response.body.accessToken}}

### Get key exchange status
GET {{AIRoundTableSecretSharingAPI_HostAddress}}/api/keyexchange/status
Accept: application/json
Authorization: Bearer {{partnerAAuth.response.body.accessToken}}

### Submit a metric (authenticated as partnerA — producerId is taken from token)
POST {{AIRoundTableSecretSharingAPI_HostAddress}}/api/metrics/submit
Content-Type: application/json
Authorization: Bearer {{partnerAAuth.response.body.accessToken}}

{
  "country": "US",
  "month": "2025-01-01",
  "value": 1230000,
  "epochId": 1,
  "signature": "demo"
}

### Get aggregate (admin only)
GET {{AIRoundTableSecretSharingAPI_HostAddress}}/api/metrics/aggregate?country=US&month=2025-01
Accept: application/json
Authorization: Bearer {{adminAuth.response.body.accessToken}}

### Add a new producer (admin only)
POST {{AIRoundTableSecretSharingAPI_HostAddress}}/api/registry/producers
Content-Type: application/json
Authorization: Bearer {{adminAuth.response.body.accessToken}}

{
  "producerId": "partnerD",
  "displayName": "Partner D",
  "startDate": "2026-06-01"
}

### Reset DB to initial state (admin only) — clears all submissions, keys, ciphertexts, producers, epochs and re-seeds
POST {{AIRoundTableSecretSharingAPI_HostAddress}}/api/admin/reset
Authorization: Bearer {{adminAuth.response.body.accessToken}}

###
